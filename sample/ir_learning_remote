import ir
import time
import json
import os
from machine import Pin

# --- GPIO setup ---
btn_recv = Pin(8, Pin.IN, Pin.PULL_UP)
btn_send = Pin(9, Pin.IN, Pin.PULL_UP)

led_green  = Pin(3, Pin.OUT)     # Receiving
led_bule   = Pin(7, Pin.OUT)     # Receive success
led_white  = Pin(6, Pin.OUT)     # Unused
led_yellow = Pin(28, Pin.OUT)    # Error blink

led_green.off()
led_bule.off()
led_white.off()
led_yellow.off()

# --- IR initialization ---
ir.init(10, 2)  # TX pin 10, RX pin 2

# --- Save file name ---
FILENAME = "learned.json"

# Check if saved JSON exists at startup
if FILENAME in os.listdir():
    print("Found existing data")
    for _ in range(4):
        led_bule.off()
        time.sleep(0.2)
        led_bule.on()
        time.sleep(0.2)

# --- Error blink ---
def blink_error():
    for _ in range(3):
        led_yellow.on()
        time.sleep(0.2)
        led_yellow.off()
        time.sleep(0.2)

# --- Save RAW data ---
def save_raw(pulses):
    with open(FILENAME, "w") as f:
        json.dump({"raw": pulses}, f)

# --- Load RAW data ---
def load_raw():
    try:
        with open(FILENAME) as f:
            data = json.load(f)
            return tuple(data["raw"])
    except:
        return None

# --- Main loop ---
print("Ready. Press GPIO8 to learn, GPIO9 to send.")

while True:

    # --- Receive button ---
    if btn_recv.value() == 0:
        print("Receive mode start")
        led_green.on()
        led_bule.off()

        # Start receiving
        pulses = ir.receive()  # IndoorCorgi receive

        led_green.off()

        if pulses:
            print("Receive OK, length =", len(pulses))
            save_raw(pulses)
            led_bule.on()
        else:
            print("Receive failed")
            blink_error()

        # Wait until button is released
        while btn_recv.value() == 0:
            time.sleep(0.05)

    # --- Send button ---
    if btn_send.value() == 0:
        print("Send mode start")

        pulses = load_raw()

        if pulses:
            ir.send(pulses)
            print("Send OK")
        else:
            print("No data")
            blink_error()

        # Wait until button is released
        while btn_send.value() == 0:
            time.sleep(0.05)

    time.sleep(0.02)
